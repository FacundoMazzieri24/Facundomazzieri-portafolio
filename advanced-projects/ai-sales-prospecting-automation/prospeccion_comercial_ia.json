    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "output = []\n\ndef get_case_insensitive(data, key):\n    for k, v in data.items():\n        if k.lower() == key.lower():\n            return v\n    return None\n\ndef extraer_url(web):\n    web = web.strip()\n    idx = web.find(\"https://\")\n    if idx == -1:\n        idx = web.find(\"http://\")\n    if idx == -1:\n        return \"https://\" + web\n    resto = web[idx:]\n    corte = len(resto)\n    for simbolo in [\")\", \"）\", \"]\", \" \", \"\\n\"]:\n        pos = resto.find(simbolo)\n        if pos != -1 and pos < corte:\n            corte = pos\n    return resto[:corte]\n\nfor item in _items:\n    json_data = item[\"json\"]\n\n    email_contacto = get_case_insensitive(json_data, \"Email_Contacto\")\n    nombre_empresa = get_case_insensitive(json_data, \"Nombre_Empresa\")\n    web = get_case_insensitive(json_data, \"Web\")\n    pais = get_case_insensitive(json_data, \"País\")  # NUEVO: leer el campo País\n\n    if not isinstance(email_contacto, str) or not isinstance(nombre_empresa, str) or not isinstance(web, str):\n        continue\n    if \"@\" not in email_contacto or \".\" not in email_contacto.split(\"@\")[1]:\n        continue\n\n    enviado = get_case_insensitive(json_data, \"Enviado\")\n    if enviado is not None and str(enviado).strip().lower() in [\"sí\", \"si\", \"true\", \"yes\"]:\n        continue\n\n    web_limpia = extraer_url(web)\n\n    nuevo_json = dict(json_data)\n    nuevo_json[\"Email_Contacto_Cleaned\"] = email_contacto\n    nuevo_json[\"Nombre_Empresa_Cleaned\"] = nombre_empresa.strip().title()\n    nuevo_json[\"Web_Cleaned\"] = web_limpia\n    nuevo_json[\"Pais_Cleaned\"] = pais.strip().title() if isinstance(pais, str) else \"Argentina\"  # NUEVO\n\n    output.append({\"json\": nuevo_json})\n\nreturn output"
      },
